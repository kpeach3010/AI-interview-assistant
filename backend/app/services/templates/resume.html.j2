<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="utf-8" />
<style>
  :root { --accent: {{ theme }}; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    font-family: "Segoe UI", "Be Vietnam Pro", Arial, "Helvetica Neue", sans-serif;
    color: #1f2937;
    font-size: 10.5pt;
    line-height: 1.45;
    -webkit-print-color-adjust: exact;
  }
  body { padding: 0; }

  /* Header */
  .header { border-bottom: 2.5pt solid var(--accent); padding-bottom: 10px; margin-bottom: 14px; }
  .name { font-size: 22pt; font-weight: 700; color: #0f172a; letter-spacing: .2px; }
  .role { font-size: 12pt; font-weight: 600; color: var(--accent); margin-top: 2px; }
  .contact { margin-top: 6px; font-size: 9pt; color: #475569; }
  .contact span { white-space: nowrap; }
  .contact .sep { color: #cbd5e1; margin: 0 6px; }

  /* Sections */
  .section { margin-top: 14px; page-break-inside: avoid; }
  .section h2 {
    font-size: 11pt; font-weight: 700; text-transform: uppercase; letter-spacing: .6px;
    color: var(--accent); border-bottom: 1pt solid #e2e8f0;
    padding-bottom: 3px; margin-bottom: 7px;
  }

  .summary { color: #334155; text-align: justify; }

  /* Skills */
  .skills { display: flex; flex-wrap: wrap; gap: 5px 7px; }
  .skill {
    font-size: 9pt; background: #f1f5f9; color: #334155;
    padding: 2.5px 8px; border-radius: 4px; border: .5pt solid #e2e8f0;
  }

  /* Entry blocks (experience/projects/education) */
  .entry { margin-bottom: 10px; page-break-inside: avoid; }
  .entry:last-child { margin-bottom: 0; }
  .entry-head { display: flex; justify-content: space-between; align-items: baseline; gap: 10px; }
  .entry-title { font-weight: 700; color: #0f172a; font-size: 10.5pt; }
  .entry-period { font-size: 9pt; color: #64748b; white-space: nowrap; }
  .entry-sub { font-size: 9.5pt; color: #475569; font-style: italic; margin-top: 1px; }
  .tech { font-size: 9pt; color: var(--accent); margin-top: 2px; }

  ul.bullets { list-style: none; margin-top: 4px; }
  ul.bullets li { position: relative; padding-left: 13px; margin-top: 2.5px; color: #334155; }
  ul.bullets li::before {
    content: ""; position: absolute; left: 2px; top: 6px;
    width: 4px; height: 4px; border-radius: 50%; background: var(--accent);
  }
</style>
</head>
<body>

  <div class="header">
    <div class="name">{{ name }}</div>
    {% if position %}<div class="role">{{ position }}</div>{% endif %}
    <div class="contact">
      {%- set items = [] -%}
      {%- if email %}{% set _ = items.append(email) %}{% endif -%}
      {%- if phone %}{% set _ = items.append(phone) %}{% endif -%}
      {%- if address %}{% set _ = items.append(address) %}{% endif -%}
      {%- for it in items -%}
        <span>{{ it }}</span>{% if not loop.last %}<span class="sep">•</span>{% endif %}
      {%- endfor -%}
    </div>
  </div>

  {% if summary %}
  <div class="section">
    <h2>Mục tiêu nghề nghiệp</h2>
    <div class="summary">{{ summary }}</div>
  </div>
  {% endif %}

  {% if skills %}
  <div class="section">
    <h2>Kỹ năng chuyên môn</h2>
    <div class="skills">
      {% for s in skills %}<span class="skill">{{ s }}</span>{% endfor %}
    </div>
  </div>
  {% endif %}

  {% if experiences %}
  <div class="section">
    <h2>Kinh nghiệm làm việc</h2>
    {% for e in experiences %}
    <div class="entry">
      <div class="entry-head">
        <span class="entry-title">{{ e.role or "—" }}{% if e.company %} @ {{ e.company }}{% endif %}</span>
        {% if e.period %}<span class="entry-period">{{ e.period }}</span>{% endif %}
      </div>
      {% if e.highlights %}
      <ul class="bullets">
        {% for h in e.highlights %}<li>{{ h }}</li>{% endfor %}
      </ul>
      {% endif %}
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {% if projects %}
  <div class="section">
    <h2>Dự án tiêu biểu</h2>
    {% for p in projects %}
    <div class="entry">
      <div class="entry-head">
        <span class="entry-title">{{ p.name or "Dự án" }}{% if p.role %} — {{ p.role }}{% endif %}</span>
      </div>
      {% if p.tech_stack %}<div class="tech">{{ p.tech_stack | join(", ") }}</div>{% endif %}
      {% if p.description %}<div class="entry-sub" style="font-style:normal;">{{ p.description }}</div>{% endif %}
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {% if education %}
  <div class="section">
    <h2>Học vấn</h2>
    {% for ed in education %}
    <div class="entry">
      <div class="entry-head">
        <span class="entry-title">{{ ed.school or "—" }}</span>
        {% if ed.period %}<span class="entry-period">{{ ed.period }}</span>{% endif %}
      </div>
      {% if ed.degree %}<div class="entry-sub">{{ ed.degree }}</div>{% endif %}
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {% if achievements %}
  <div class="section">
    <h2>Chứng chỉ &amp; Thành tựu</h2>
    <ul class="bullets">
      {% for a in achievements %}<li>{{ a }}</li>{% endfor %}
    </ul>
  </div>
  {% endif %}

</body>
</html>
