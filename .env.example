# Supabase (Dashboard → Settings → API)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
DATABASE_URL=postgresql://postgres.[ref]:[pass]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_DATABASE_URL=postgresql://postgres.[ref]:[pass]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# LLM Hybrid
# LLM_PREFER: auto | local | cloud | groq | gemini | ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Google Gemini (miễn phí: 15 req/min, 1M tokens/ngày)
# Lấy tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Groq (miễn phí: 14,400 req/ngày, latency < 1s)
# Lấy tại: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
# Model mạnh hơn cho tác vụ nền cần chất lượng (sinh câu hỏi, review CV, parse CV)
GROQ_QUALITY_MODEL=llama-3.3-70b-versatile

LLM_PREFER=auto

# Hội đồng phỏng vấn đa tác nhân (Lead orchestrator + chuyên gia + scorekeeper).
# PANEL_ENABLED=false để quay lại luồng phỏng vấn tuyến tính cũ.
PANEL_ENABLED=true
PANEL_MAX_QUESTIONS=12
# Cho phép panel sinh câu hỏi động ngoài kho khi có chủ đề nổi lên từ câu trả lời.
PANEL_ALLOW_GENERATE=true
PANEL_MAX_EMERGENT_GOALS=3

# Voice
WHISPER_MODEL=small
WHISPER_DEVICE=cpu

# App
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Frontend (Vite)
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_API_URL=http://localhost:8000
